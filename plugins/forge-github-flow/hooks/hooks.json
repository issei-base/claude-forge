{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/hooks/git-push-guard.py",
            "timeout": 5,
            "statusMessage": "Checking git push target (main/master guard)"
          }
        ]
      }
    ]
  }
}
