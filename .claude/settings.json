{
  "mcpServers": {
    "aws": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(codex exec:*)",
      "Bash(gws sheets:*)",
      "Bash(gws auth status:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.claude/.credentials.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-lint.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
