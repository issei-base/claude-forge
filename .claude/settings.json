{
  "mcpServers": {
    "aws": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(codex exec:*)",
      "Bash(gws sheets:*)",
      "Bash(gws docs:*)",
      "Bash(gws drive:*)",
      "Bash(gws auth status:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-lint.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
