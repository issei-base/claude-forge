{
  "skillListingBudgetFraction": 0.02,
  "enableAllProjectMcpServers": false,
  "mcpServers": {
    "aws": {
      "command": "uvx",
      "args": [
        "awslabs.aws-documentation-mcp-server@1.1.26"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(codex exec:*)",
      "Bash(gws sheets:*)",
      "Bash(gws auth status:*)",
      "Bash(which:*)",
      "Bash(gemini:*)",
      "Bash(marp:*)",
      "Bash(printenv:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.claude/.credentials.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-push-guard.py\"",
            "timeout": 5,
            "statusMessage": "Checking git push target (main/master guard)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-lint.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
