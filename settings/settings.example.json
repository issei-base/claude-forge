{
  "_comment": "Template for ~/.claude/settings.json. Copy contents into your real settings.json by hand — install.sh does NOT touch settings.json because Claude Code rewrites it at runtime.",

  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": ["-y", "mcp-obsidian", "/Users/issei/obsidian/issei"]
    },
    "aws": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ]
    }
  },

  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(codex exec:*)",
      "Bash(gws sheets:*)",
      "Bash(gws docs:*)",
      "Bash(gws drive:*)",
      "Bash(gws auth status:*)"
    ]
  }
}
